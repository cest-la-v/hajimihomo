# hajimihomo — mihomo profile (generated by build_profile.py)
# Reference: https://wiki.metacubex.one/en_US/config/
{% if target == 'mihomo-smart' %}
# ⚠️  This profile uses smart proxy groups which require the vernesong/mihomo fork:
#     https://github.com/vernesong/mihomo
#     Do NOT use with standard MetaCubeX/mihomo — smart type is not supported there.
{% endif %}

# ── core ──────────────────────────────────────────────────────────────────────
mixed-port: 7890
allow-lan: false
bind-address: '*'
mode: rule
log-level: warning
ipv6: true
unified-delay: true
tcp-concurrent: true
find-process-mode: strict
global-client-fingerprint: chrome
global-ua: mihomo
keep-alive-idle: 600
keep-alive-interval: 60
etag-support: true
{% if target == 'mihomo-smart' %}
lgbm-auto-update: true
lgbm-update-interval: 24
lgbm-url: 'https://github.com/vernesong/mihomo/releases/download/LightGBM-Model/Model-large.bin'
{% endif %}

# ── geodata ───────────────────────────────────────────────────────────────────
geodata-mode: true
geo-auto-update: true
geo-update-interval: 168
geox-url:
  geoip: "https://github.com/cest-la-v/hajimihomo/releases/latest/download/geoip.mmdb"
  geosite: "https://github.com/cest-la-v/hajimihomo/releases/latest/download/geosite.dat"

# ── profile ───────────────────────────────────────────────────────────────────
profile:
  store-selected: true
  store-fake-ip: true
{% if target == 'mihomo-smart' %}
  smart-collector-size: 1024
{% endif %}

# ── dns ───────────────────────────────────────────────────────────────────────
dns:
  enable: true
  ipv6: true
  listen: 0.0.0.0:1053
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-range6: 3fff::/20
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - '*.localhost'
    - '+.stun.*.*'
    - '+.stun.*.*.*'
    - 'time.*.com'
    - 'time.*.gov'
    - 'time.*.edu.cn'
    - '+.ntp.org.cn'
    - 'ntp.*.com'
  cache-algorithm: arc
  respect-rules: false
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
  fallback:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
    - https://9.9.9.9/dns-query
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4
{% if hosts %}

# ── hosts (DNS-polluted domains — real IPs) ───────────────────────────────────
hosts:
{{ hosts }}
{% endif %}

# ── tun (disabled by default — uncomment to enable) ──────────────────────────
# tun:
#   enable: false
#   stack: mixed
#   auto-route: true
#   auto-redirect: true
#   auto-detect-interface: true
#   dns-hijack:
#     - any:53

# ── sniffer ───────────────────────────────────────────────────────────────────
sniffer:
  enable: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443]
  skip-domain:
    - 'Mijia Cloud'
    - '+.push.apple.com'

# ── anchors (not real YAML keys — mihomo ignores unknown top-level keys) ──────
p: &BaseProvider
  type: http
  interval: 86400
  proxy: DIRECT
  health-check:
    enable: true
    url: 'https://www.google.com/generate_204'
    interval: 300
  filter: "^(?!.*(群|订阅|到期|流量|机场|官网|邮箱|通知|Panel|Author|TOTAL|EXPIRE)).*$"

g:
  s: &BaseSelect
    type: select
  a: &BaseAutoTest
    type: url-test
    url: 'https://www.google.com/generate_204'
    interval: 200
    lazy: true
    hidden: true
  f: &BaseFallback
    type: fallback
    url: 'https://www.google.com/generate_204'
    interval: 200
    lazy: true
  lh: &BaseLBHash
    type: load-balance
    strategy: consistent-hashing
    url: 'https://www.google.com/generate_204'
    interval: 200
    lazy: true
    hidden: true
  lr: &BaseLBRR
    type: load-balance
    strategy: round-robin
    url: 'https://www.google.com/generate_204'
    interval: 200
    lazy: true
    hidden: true

f:
  hk: &FilterHK '^(?=.*(?i)(港|🇭🇰|HK|Hong Kong|HKG))(?!.*{{ exclude_filter }}).*$'
  sg: &FilterSG '^(?=.*(?i)(坡|新加坡|🇸🇬|SG|Sing|SIN|XSP))(?!.*{{ exclude_filter }}).*$'
  jp: &FilterJP '^(?=.*(?i)(日本|日|🇯🇵|JP|Japan|NRT|HND|KIX))(?!.*{{ exclude_filter }}).*$'
  kr: &FilterKR '^(?=.*(?i)(韩|韩国|🇰🇷|KR|Korea|ICN))(?!.*{{ exclude_filter }}).*$'
  us: &FilterUS '^(?=.*(?i)(美|美国|🇺🇸|US|USA|LAX|SJC|JFK|ORD))(?!.*{{ exclude_filter }}).*$'
  tw: &FilterTW '^(?=.*(?i)(台|台湾|🇹🇼|TW|TPE|TSA))(?!.*{{ exclude_filter }}).*$'
  eu: &FilterEU '^(?=.*(?i)(英|法|德|荷|瑞|🇬🇧|🇫🇷|🇩🇪|🇳🇱|🇸🇪|UK|GB|FR|DE|NL|SE|CDG|FRA|AMS|LHR))(?!.*{{ exclude_filter }}).*$'
  all: &FilterALL '^(?!.*(DIRECT|直连|群|订阅|到期|流量|机场|官网|通知|Panel|Author|{{ exclude_filter }})).*$'

# ── proxy providers ───────────────────────────────────────────────────────────
proxy-providers:
{{ proxy_providers }}

# ── proxy groups ──────────────────────────────────────────────────────────────
proxy-groups:
{{ proxy_groups }}

# ── rule providers ────────────────────────────────────────────────────────────
rule-providers:
{{ rule_providers }}

# ── rules ─────────────────────────────────────────────────────────────────────
rules:
{{ rules }}
